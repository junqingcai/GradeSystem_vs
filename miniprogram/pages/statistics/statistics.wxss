.stat-list {
  border-top: 1rpx solid #edf2f7;
}

.stat-line {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.income {
  color: #1f7a5a;
  font-weight: 700;
}

.expense {
  color: #d9480f;
  font-weight: 700;
}

.rank-row {
  padding: 24rpx 0;
  border-top: 1rpx solid #edf2f7;
}

.rank-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bar {
  flex: 1;
  height: 14rpx;
  margin-left: 24rpx;
  overflow: hidden;
  background: #edf2f7;
  border-radius: 8rpx;
}

.bar-inner {
  height: 14rpx;
  background: #1f7a5a;
  border-radius: 8rpx;
}

.rank-money {
  margin-top: 12rpx;
  color: #52606d;
  font-size: 24rpx;
}
