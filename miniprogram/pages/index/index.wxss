.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  margin-bottom: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.summary-card {
  background: #1f7a5a;
  color: #ffffff;
}

.summary-card .muted {
  color: rgba(255, 255, 255, 0.78);
}

.balance {
  margin: 12rpx 0;
  font-size: 64rpx;
  font-weight: 700;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-card {
  margin-bottom: 0;
}

.stat-card .money {
  margin-top: 12rpx;
  font-size: 36rpx;
}

.income {
  color: #1f7a5a;
}

.expense {
  color: #d9480f;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 24rpx 0;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-top: 1rpx solid #edf2f7;
}

.record-row:first-of-type {
  border-top: 0;
}

.small {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.amount-expense {
  color: #d9480f;
  font-weight: 700;
}

.amount-income {
  color: #1f7a5a;
  font-weight: 700;
}
