<view class="page">
  <view class="card">
    <view class="section-title">{{isEdit ? '修改记录' : '添加记录'}}</view>

    <view class="form-item">
      <view class="label">记录类型</view>
      <picker mode="selector" range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="changeType">
        <view class="picker">{{typeOptions[typeIndex].label}}</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">日期</view>
      <picker mode="date" value="{{date}}" bindchange="changeDate">
        <view class="picker">{{date}}</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">金额</view>
      <input class="input" type="digit" placeholder="请输入金额" value="{{amount}}" bindinput="inputAmount" />
    </view>

    <view class="form-item">
      <view class="label">分类</view>
      <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="changeCategory">
        <view class="picker">{{category}}</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">备注</view>
      <input class="input" placeholder="例如 早餐、地铁、兼职" value="{{remark}}" bindinput="inputRemark" />
    </view>
  </view>

  <button class="btn" bindtap="saveRecord">保存记录</button>
</view>
