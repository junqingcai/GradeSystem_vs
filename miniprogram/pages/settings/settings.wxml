<view class="page">
  <view class="card">
    <view class="section-title">本月预算</view>
    <view class="muted">当前月份：{{currentMonth}}</view>
    <input class="input" type="digit" placeholder="请输入本月生活费预算" value="{{budgetInput}}" bindinput="inputBudget" />
    <button class="btn save-btn" bindtap="saveBudget">保存预算</button>
  </view>

  <view class="card">
    <view class="section-title">支出分类</view>
    <view class="add-row">
      <input class="input category-input" placeholder="新增支出分类" value="{{newExpenseCategory}}" bindinput="inputExpenseCategory" />
      <button class="btn small-btn" bindtap="addExpenseCategory">添加</button>
    </view>
    <view class="tag-list">
      <text wx:for="{{categories.expense}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
  </view>

  <view class="card">
    <view class="section-title">收入分类</view>
    <view class="add-row">
      <input class="input category-input" placeholder="新增收入分类" value="{{newIncomeCategory}}" bindinput="inputIncomeCategory" />
      <button class="btn small-btn" bindtap="addIncomeCategory">添加</button>
    </view>
    <view class="tag-list">
      <text wx:for="{{categories.income}}" wx:key="*this" class="tag income-tag">{{item}}</text>
    </view>
  </view>
</view>
