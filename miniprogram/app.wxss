page {
  min-height: 100%;
  background: #f5f7fb;
  color: #1f2933;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.section-title {
  margin-bottom: 20rpx;
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 600;
}

.muted {
  color: #7b8794;
}

.money {
  font-weight: 700;
  color: #1f7a5a;
}

.btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #1f7a5a;
  font-size: 28rpx;
}

.btn::after {
  border: 0;
}

.btn-secondary {
  color: #1f7a5a;
  background: #e5f5ef;
}

.btn-danger {
  color: #c62828;
  background: #fdecea;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 76rpx;
  margin-top: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d9e2ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.empty {
  padding: 56rpx 20rpx;
  text-align: center;
  color: #7b8794;
}
